{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    // Index signature access returns T | undefined so callers must handle the
    // possibility that an index is out of bounds.
    "noUncheckedIndexedAccess": true,
    // Optional properties cannot be explicitly assigned undefined; must be
    // omitted entirely if no value is provided.
    "exactOptionalPropertyTypes": true,
    // `@/*` maps to `src/*` so anywhere in the codebase can write
    // `import { X } from "@/types/Student"` instead of multi-hop relative
    // paths like `../../types/Student`. Mirrored in vite.config.ts so the
    // dev server + production build resolve the same paths at runtime.
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
